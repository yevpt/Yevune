# 复制为 .env 并填写。docker compose 会自动读取同目录 .env。

# 密码加密与会话签名密钥：设为随机长串，例如 `openssl rand -hex 32`
YEVUNE_APP_SECRET=change-me-to-a-long-random-string

# Garage 访问密钥（初始化 Garage 后得到，见 README）
GARAGE_ACCESS_KEY=
GARAGE_SECRET_KEY=

# 首启管理员（可选）。留空 YEVUNE_ADMIN_PASSWORD 则服务端生成随机密码并打印在启动日志。
YEVUNE_ADMIN_USERNAME=admin
YEVUNE_ADMIN_PASSWORD=
